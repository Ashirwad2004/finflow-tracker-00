{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FinFlow",
  "version": "1.0.0",
  "identifier": "com.ashirwad.finflow",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FinFlow Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.supabase.co wss://*.supabase.co blob: data:;"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ashirwad/finflow/releases/latest/download/updater.json"
      ],
      "pubkey": "UPDATE_KEY",
      "dialog": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "The financial operating system designed for modern freelancers and businesses to scale with confidence.",
    "longDescription": "Stop guessing. Start growing. The financial operating system designed for modern freelancers and businesses to scale with confidence.",
    "publisher": "Ashirwad",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
