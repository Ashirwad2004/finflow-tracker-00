{
  "name": "finflow-tracker-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "FinFlow Tracker - Monorepo housing FastAPI backend and React frontend",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "clean-dev": "npm run clean-dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "backend:dev": "cd backend && uvicorn main:app --reload",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
